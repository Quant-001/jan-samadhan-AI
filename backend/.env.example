# ─── Jan Samadhan AI — Backend Environment Variables ───────────────────────
# Copy this file to .env and fill in your values

# Django
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
AXES_ENABLED=False

# Database (local PostgreSQL)
DB_NAME=jan_samadhan
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=disable
# DB_CHANNEL_BINDING=require

# Redis (local)
REDIS_URL=redis://localhost:6379/0

# Email (use Gmail app password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password
DEFAULT_FROM_EMAIL=noreply@jansamadhan.in

# CORS (React dev server)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Sentry (optional free error monitoring — https://sentry.io)
SENTRY_DSN=

# ─── Production (Render/Neon) — uncomment and fill ─────────────────────────
# DB_HOST=your-neon-or-supabase-host
# DB_NAME=your_db_name
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_PORT=5432
# REDIS_URL=redis://your-redis-url
# ALLOWED_HOSTS=your-render-app.onrender.com
# CORS_ALLOWED_ORIGINS=https://your-vercel-app.vercel.app
# DEBUG=False
